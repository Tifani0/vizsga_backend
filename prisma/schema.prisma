generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role{
  PROVIDER 
  CUSTOMER
}
enum Profession{
  Kozmetikus
  Fodrász
  Műkörmös
}

model User{
  id Int @id @default(autoincrement())
  name String
  email String
  password String
  phonenumber String
  role Role @default(CUSTOMER)
  profession Profession?
  services Service[]
}
model Service{
  id Int @id @default(autoincrement())
  name String
  description String
  duration Int
  price Int

  userId Int
  user User @relation(fields:[userId], references: [id])
}